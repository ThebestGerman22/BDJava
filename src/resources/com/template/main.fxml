<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="455.0" prefWidth="710.0" styleClass="root" stylesheets="@../../css/estilos.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.template.MainController">


    <children>
      <ImageView fitHeight="1000.0" fitWidth="1000.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../FundoGradiente.jpg" />
         </image>
      </ImageView>
        <Button fx:id="btnSalvar" layoutX="35.0" layoutY="166.0" mnemonicParsing="false" onAction="#btnSalvarAction" onMouseClicked="#carregarCampos" style="-fx-background-color: white; -fx-border-radius: 2; -fx-border-color: black;" text="Salvar" />
        <TextField fx:id="txtNome" layoutX="129.0" layoutY="99.0" promptText="Nome" />
        <TableView fx:id="tblEspecialidadesMedicas" layoutX="129.0" layoutY="173.0" onMouseClicked="#carregarCampos" prefHeight="200.0" prefWidth="469.0" style="-fx-background-color: #d8ebf2; -fx-border-width: 3; -fx-border-color: #0062cc;" AnchorPane.bottomAnchor="27.0" AnchorPane.topAnchor="173.0">
            <columns>
                <TableColumn fx:id="colId" prefWidth="75.0" text="ID" />
                <TableColumn fx:id="colNome" prefWidth="75.0" text="Nome" />
                <TableColumn fx:id="colEmail" prefWidth="75.0" text="Email" />
                <TableColumn fx:id="colSenha" prefWidth="75.0" text="Senha" />
                <TableColumn fx:id="colLogin" prefWidth="75.0" text="Login" />
                <TableColumn fx:id="colEspecialidade" prefWidth="93.0" text="Especialidade" />
            </columns>
        </TableView>
        <TextField fx:id="txtEmail" layoutX="289.0" layoutY="99.0" promptText="Email" />
        <TextField fx:id="txtSenha" layoutX="195.0" layoutY="132.0" promptText="Senha" />
        <TextField fx:id="txtLogin" layoutX="449.0" layoutY="99.0" promptText="Login" />
        <TextField fx:id="txtEspecialidade" layoutX="364.0" layoutY="132.0" promptText="Especialidade" />
        <Label layoutX="166.0" layoutY="25.0" prefHeight="25.0" prefWidth="371.0" style="-fx-font-family: Verdana; -fx-font-size: 20; -fx-text-background-color: black; -fx-font-weight: bold;" text="CADASTRO DE FUNCIONARIOS" />
        <Button fx:id="btnAtualizar" layoutX="34.0" layoutY="250.0" mnemonicParsing="false" onAction="#btnAtualizarAction" style="-fx-background-color: white; -fx-border-radius: 3; -fx-border-color: black;" text="Alterar" />
        <Button fx:id="btnDeletar" layoutX="32.0" layoutY="208.0" mnemonicParsing="false" onAction="#btnDeletarAction" style="-fx-background-color: red; -fx-border-color: Black; -fx-border-radius: 3;" text="Deletar" />
        <Button fx:id="btnLimpar" layoutX="34.0" layoutY="295.0" mnemonicParsing="false" onAction="#btnLimparAction" style="-fx-background-color: cyan; -fx-border-radius: 3; -fx-border-color: black;" text="Limpar" />
    </children>
</AnchorPane>
